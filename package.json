  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun scripts/dev.build.ts",
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "format": "prettier --write .",
    "update": "turbo run update && npm-check-updates -u -x @types/node",
    "prepack": "bun scripts/compile.build.ts",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dannycreations/Peke.git"
  },
  "homepage": "https://github.com/dannycreations/Peke",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "es-toolkit": "^1.47.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "22.19.15",
    "chokidar": "^5.0.0",
    "husky": "^9.1.7",
    "npm-check-updates": "^22.2.5",
    "prettier": "^3.8.4",
    "terser": "^5.48.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-checker": "^0.14.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.14"
